install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/ChessGame_223637/bin || mkdir -p $(INSTALL_ROOT)/opt/ChessGame_223637/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/ChessGame_223637/bin/ChessGame_223637.app
	
	$(QINSTALL) ChessGame_223637.app $(INSTALL_ROOT)/opt/ChessGame_223637/bin/ChessGame_223637.app
	-$(STRIP) $(INSTALL_ROOT)/opt/ChessGame_223637/bin/ChessGame_223637.app/Contents/MacOS/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/ChessGame_223637/bin/ChessGame_223637.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/ChessGame_223637/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

